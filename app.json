{
  "expo": {
    "name": "Kolasys AI",
    "slug": "kolasys-ai-mobile",
    "owner": "kolasysai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kolasystems.kolasysai",
      "appleTeamId": "G4FYFLNJMC",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Kolasys AI needs microphone access to record meetings.",
        "NSCalendarsUsageDescription": "Kolasys AI uses your calendar to show upcoming meetings.",
        "NSCalendarsFullAccessUsageDescription": "Kolasys AI uses your calendar to show upcoming meetings.",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.kolasystems.kolasysai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "RECORD_AUDIO",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": "Kolasys AI needs microphone access to record meetings."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#CA2625",
          "sounds": []
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Kolasys AI uses your calendar to show upcoming meetings."
        }
      ]
    ],
    "scheme": "kolasys-ai",
    "extra": {
      "clerkPublishableKey": "pk_live_Y2xlcmsuYXBwLmtvbGFzeXMuYWkk",
      "eas": {
        "projectId": "b6cab2a6-d1df-4288-b887-4a9a4860766a"
      }
    }
  }
}
